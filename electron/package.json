{
  "name": "tapdot-desktop",
  "productName": "tapdot",
  "version": "1.0.2",
  "description": "90+ privacy-first tools, fully offline — the native desktop app",
  "homepage": "https://tools.tapdot.org/desktop/",
  "main": "src/main.js",
  "author": {
    "name": "Mohan Venkatakrishnan",
    "email": "rkmohanchn@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "copy-tools": "node scripts/copy-tools.mjs",
    "prestart": "npm run copy-tools",
    "start": "electron .",
    "predist": "npm run copy-tools",
    "dist": "electron-builder --mac --win --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "generate-catalog": "node ../scripts/generate-desktop-catalog.mjs"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0",
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "org.tapdot.desktop",
    "productName": "tapdot",
    "copyright": "Copyright (c) 2026 Mohan Venkatakrishnan",
    "files": [
      "src/**/*",
      "tools/**/*",
      "assets/**/*",
      "!tools/**/.git",
      "!tools/test/**",
      "!tools/electron/**",
      "!**/.DS_Store",
      "!**/node_modules/**"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "afterPack": "scripts/adhoc-sign.mjs",
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "deb": {
      "synopsis": "90+ privacy-first tools, fully offline"
    },
    "dmg": {
      "title": "tapdot ${version}",
      "window": { "width": 540, "height": 380 }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [{
      "provider": "github",
      "owner": "mohan-venkatakrishnan",
      "repo": "tapdot-tools",
      "releaseType": "release"
    }]
  }
}
